# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
/gofly

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Compiled CLI binary (build artifact, not tracked)
/bin/gofly

# Volatile benchmark run output (baseline.txt is tracked)
bench/current.txt

# Temporary test caches (GOCACHE/GOTMPDIR)
.tmp-test/

# Generated docs and long-form examples
.harness
docs/*
docs/superpowers
!docs/index.md
!docs/getting-started/
!docs/getting-started/*.md
!docs/tutorials/
!docs/tutorials/*.md
!docs/how-to/
!docs/how-to/*.md
!docs/reference/
!docs/reference/*.md
!docs/explanation/
!docs/explanation/*.md
!docs/concepts/
!docs/concepts/*.md
!docs/guides/
!docs/guides/*.md
!docs/comparisons/
!docs/comparisons/*.md
!docs/case-studies/
!docs/case-studies/*.md
!docs/operations/
!docs/operations/*.md
!docs/releases/
!docs/releases/*.md
!docs/doc/
!docs/doc/*.md

# Dependency directories (remove the comment below to include it)
vendor/
report.html

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
.idea/
.vscode/
