{
  "artifacts": {
    "currentRaw": {
      "command": "make bench-stat",
      "path": "bench/current.txt",
      "tracked": false
    },
    "publicBaseline": {
      "command": "make bench-baseline",
      "path": "bench/evidence.md",
      "tracked": true
    },
    "regressionReport": {
      "command": "make bench-regression-check",
      "path": "bench/regression-report.json",
      "schema": "gofly.benchmark_regression_report.v1",
      "tracked": false
    },
    "trendSummary": {
      "command": "make bench-trend",
      "path": "bench/summary.md",
      "tracked": false
    }
  },
  "releaseRule": {
    "attach": [
      "raw output from make bench-stat",
      "bench/summary.md from make bench-trend",
      "bench/regression-report.json from make bench-regression-check",
      "bench/evidence.md when publishing a new public baseline"
    ],
    "changedAreas": [
      "REST",
      "RPC",
      "gateway",
      "governance",
      "OpenAPI",
      "code generation hot paths"
    ],
    "notes": [
      "include significant benchstat rows",
      "state environment from bench/evidence.md",
      "state allocation regression status",
      "state latency is report-only unless promoted by policy"
    ]
  },
  "schema": "gofly.benchmark_publishing.v1"
}
