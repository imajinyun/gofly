{
  "schema": "gofly.dx_support_bundle.v1",
  "acceptanceGate": "make dx-troubleshooting-check",
  "surfaces": [
    {
      "command": "gofly doctor --json",
      "outputMode": "raw-json",
      "stableFields": [
        "version",
        "go",
        "os",
        "arch",
        "checks",
        "summary",
        "nextActions"
      ],
      "failureGuidance": "warn and fail checks must include fix_hint or nextActions",
      "nextActionRequired": true
    },
    {
      "command": "gofly bug --json",
      "outputMode": "raw-json",
      "stableFields": [
        "tool",
        "version",
        "environment",
        "checks",
        "supportBundle",
        "nextActions"
      ],
      "supportBundleSchema": "gofly.support_bundle.v1",
      "failureGuidance": "support bundles must include redaction policy, diagnostic commands, and next actions before sharing",
      "redactionPolicy": [
        "Authorization",
        "Cookie",
        "Set-Cookie",
        "GOFLY_LLM_*",
        "*TOKEN*",
        "*SECRET*",
        "*PASSWORD*"
      ],
      "nextActionRequired": true
    },
    {
      "command": "gofly release check --json --strict",
      "outputMode": "json-envelope",
      "stableFields": [
        "ok",
        "command",
        "data.summary",
        "data.checks",
        "error.remediation"
      ],
      "failureGuidance": "blocking release errors must include structured remediation",
      "nextActionRequired": false
    },
    {
      "command": "gofly ai new --json --apply --verify",
      "outputMode": "json-envelope",
      "stableFields": [
        "data.verification",
        "data.verifyRan",
        "data.verifyPassed",
        "data.nextActions"
      ],
      "failureGuidance": "generated project verification failures must report command, status, bounded output, error, and rerun guidance",
      "nextActionRequired": true
    }
  ],
  "generatedFailureReport": {
    "schema": "gofly.generated_project_failure_report.v1",
    "fields": [
      "command",
      "status",
      "output",
      "error",
      "nextActions"
    ],
    "boundedOutput": true,
    "outputLimitBytes": 4096,
    "statusValues": [
      "passed",
      "failed",
      "skipped"
    ],
    "rerunGuidanceField": "nextActions",
    "redactionRequired": true,
    "redactionTerms": [
      "Authorization",
      "Cookie",
      "Set-Cookie",
      "GOFLY_LLM_*",
      "*TOKEN*",
      "*SECRET*",
      "*PASSWORD*"
    ],
    "evidenceProducers": [
      {
        "command": "gofly ai new --json --apply --verify",
        "fields": [
          "data.verification",
          "data.nextActions"
        ]
      }
    ],
    "ciArtifactUsage": "Attach the bounded verification result object as a CI artifact and rerun only the command named in nextActions after fixing the reported error."
  },
  "remediationHandoff": {
    "schema": "gofly.remediation_handoff.v1",
    "aiflowTask": "GOFLY-GOV-10P9-09",
    "supersedes": [
      "GOFLY-KG-07-AI-REMEDIATION-AIFLOW",
      "GOFLY-GOV-10R7-09"
    ],
    "owner": "human-or-current-agent",
    "commitPolicy": "aiflow may queue tasks, run diagnostics, and produce remediation plans, but it must not create commits or push; commits are made by the current agent or human after gates pass",
    "allowedActions": [
      "queue remediation tasks",
      "run diagnostic commands",
      "produce patch plans",
      "produce bounded failure reports"
    ],
    "forbiddenActions": [
      "git commit",
      "git push",
      "modify docs/superpowers/",
      "stage runtime state"
    ],
    "inputs": [
      "gofly doctor --json",
      "gofly release check --json --strict",
      "gofly bug --json",
      "gofly.generated_project_failure_report.v1"
    ],
    "requiredGates": [
      "make dx-troubleshooting-check",
      "make governance-report-check",
      "go test -shuffle=on ./cmd/gofly/internal/command -run 'TestCLIJSONContractGoldens|TestCLIJSONErrorEnvelopeGolden'"
    ],
    "outputFields": [
      "taskId",
      "sourceCommand",
      "remediation",
      "nextActions",
      "gates",
      "commitPolicy"
    ],
    "completionPolicy": "mark the aiflow task complete only after the current agent or human records a commit with passing gates and no runtime state staged"
  },
  "p9RemediationCloseout": {
    "schema": "gofly.p9_remediation_closeout.v1",
    "aiflowTask": "GOFLY-GOV-10P9-09",
    "acceptanceGate": "make dx-troubleshooting-check",
    "sourceCommands": [
      "gofly doctor --json",
      "gofly release check --json --strict",
      "gofly bug --json",
      "gofly ai new --json --apply --verify"
    ],
    "requiredNextActionSources": [
      "nextActions",
      "error.remediation",
      "data.nextActions"
    ],
    "handoffOutputFields": [
      "taskId",
      "sourceCommand",
      "remediation",
      "nextActions",
      "gates",
      "commitPolicy"
    ],
    "runtimeStatePolicy": "Do not stage .aiflow, .harness, .tmp-test, .trae, coverage.out, or docs/superpowers while resolving remediation tasks.",
    "completionPolicy": "Only mark GOFLY-GOV-10P9-09 complete after dx-troubleshooting-check and CLI JSON contract gates pass and no runtime state is staged.",
    "nextActionPolicy": "Every failed doctor, release, generated-project, or support-bundle path must expose nextActions or error.remediation before aiflow can queue bounded remediation work."
  },
  "supportWorkflow": [
    "run gofly doctor --json",
    "run gofly release check --json --strict",
    "run gofly bug --json",
    "attach generated project verification failure reports when available"
  ],
  "troubleshootingAdoptionLoop": {
    "schema": "gofly.troubleshooting_adoption_loop.v1",
    "acceptanceGate": "make dx-troubleshooting-check",
    "dashboardReportField": "dxSupportBundle.troubleshootingAdoptionLoop",
    "aiflowHandoff": "gofly.remediation_handoff.v1",
    "commitOwner": "human-or-current-agent",
    "runtimeStatePolicy": "Do not stage .aiflow, .harness, .tmp-test, .trae, coverage.out, or docs/superpowers while resolving troubleshooting tasks.",
    "steps": [
      {
        "id": "diagnose-environment",
        "sourceCommand": "gofly doctor --json",
        "evidenceArtifact": "doctor.json",
        "requiredFields": [
          "checks",
          "summary",
          "nextActions"
        ],
        "nextActionSource": "nextActions",
        "redactionRequired": false,
        "handoffBoundary": "Use doctor output to decide whether to fix local toolchain state before editing generated or runtime code."
      },
      {
        "id": "check-release-gates",
        "sourceCommand": "gofly release check --json --strict",
        "evidenceArtifact": "release-check.json",
        "requiredFields": [
          "data.summary",
          "data.checks",
          "error.remediation"
        ],
        "nextActionSource": "error.remediation",
        "redactionRequired": false,
        "handoffBoundary": "Treat strict release blockers as release governance tasks and attach remediation before opening aiflow work."
      },
      {
        "id": "collect-support-bundle",
        "sourceCommand": "gofly bug --json",
        "evidenceArtifact": "support-bundle.json",
        "requiredFields": [
          "supportBundle",
          "supportBundle.redaction",
          "nextActions"
        ],
        "nextActionSource": "nextActions",
        "redactionRequired": true,
        "handoffBoundary": "Share only redacted support bundles and keep commit ownership outside aiflow."
      },
      {
        "id": "attach-generated-failure",
        "sourceCommand": "gofly ai new --json --apply --verify",
        "evidenceArtifact": "generated-project-failure.json",
        "requiredFields": [
          "data.verification",
          "data.nextActions"
        ],
        "nextActionSource": "data.nextActions",
        "redactionRequired": true,
        "handoffBoundary": "Attach bounded generated verification failures and rerun only the command named by nextActions."
      }
    ]
  },
  "remediationLoopContract": {
    "schema": "gofly.remediation_loop_contract.v1",
    "acceptanceGate": "make dx-troubleshooting-check",
    "dashboardReportField": "dxSupportBundle.remediationLoopContract",
    "purpose": "Tie doctor JSON, release check JSON, support bundle redaction, generated project failure reports, migration proof, dashboard fields, and next actions into one recoverable support workflow.",
    "sourceContracts": [
      {
        "id": "doctor-json",
        "sourceCommand": "gofly doctor --json",
        "evidenceArtifact": "doctor.json",
        "requiredFields": [
          "checks",
          "summary",
          "nextActions"
        ],
        "nextActionSource": "nextActions",
        "dashboardFields": [
          "dxSupportBundle.surfaceCount",
          "dxSupportBundle.remediationHintCount"
        ],
        "adopterAction": "Fix local toolchain or environment warnings before editing generated code or opening aiflow remediation work."
      },
      {
        "id": "release-check-json",
        "sourceCommand": "gofly release check --json --strict",
        "evidenceArtifact": "release-check.json",
        "requiredFields": [
          "data.summary",
          "data.checks",
          "error.remediation"
        ],
        "nextActionSource": "error.remediation",
        "dashboardFields": [
          "releaseEvidence.evidenceCount",
          "releaseAdoptionContract.supplyChainEnforcementCount"
        ],
        "adopterAction": "Treat strict release blockers as release governance tasks and attach remediation evidence before continuing adoption."
      },
      {
        "id": "support-bundle-json",
        "sourceCommand": "gofly bug --json",
        "evidenceArtifact": "support-bundle.json",
        "requiredFields": [
          "supportBundle",
          "supportBundle.redaction",
          "nextActions"
        ],
        "nextActionSource": "nextActions",
        "dashboardFields": [
          "dxSupportBundle.remediationHandoff.schema",
          "dxSupportBundle.remediationHandoff.owner"
        ],
        "redactionRequired": true,
        "adopterAction": "Share only redacted support bundle evidence and keep commit ownership with the current agent or human."
      },
      {
        "id": "generated-failure-report",
        "sourceCommand": "gofly ai new --json --apply --verify",
        "evidenceArtifact": "generated-project-failure.json",
        "requiredFields": [
          "data.verification",
          "data.nextActions"
        ],
        "nextActionSource": "data.nextActions",
        "dashboardFields": [
          "generatedUpgradeDryRun.profileCount",
          "dashboard.generatedVersionCompatibility.profileCount"
        ],
        "redactionRequired": true,
        "adopterAction": "Attach bounded generated verification output and rerun only the command named by nextActions."
      }
    ],
    "migrationRoutes": [
      {
        "id": "gin-to-gofly",
        "source": "docs/reference/framework-gap-adopter-proof.json",
        "example": "examples/migration-proof/gin-to-gofly",
        "gate": "make adopter-decision-check",
        "rollbackAction": "Keep Gin route active behind the existing router until sampled responses and metrics match.",
        "supportBundleAction": "Attach gofly bug --json only after redaction and include sampled response, OpenAPI, and error-envelope drift evidence."
      },
      {
        "id": "go-zero-to-gofly",
        "source": "docs/reference/framework-gap-adopter-proof.json",
        "example": "examples/migration-proof/go-zero-to-gofly",
        "gate": "make generated-version-compat-check",
        "rollbackAction": "Keep go-zero and gofly services addressable through discovery and switch routing back to go-zero.",
        "supportBundleAction": "Attach gofly bug --json with generated-project failure reports and release check output when scaffold compatibility fails."
      },
      {
        "id": "kratos-to-gofly",
        "source": "docs/reference/framework-gap-adopter-proof.json",
        "example": "examples/migration-proof/kratos-to-gofly",
        "gate": "make cloud-native-render-check",
        "rollbackAction": "Restore the previous Kratos deployment target while keeping shared domain services unchanged.",
        "supportBundleAction": "Attach gofly bug --json with rendered cloud-native assets, topology output, and health or discovery drift evidence."
      },
      {
        "id": "kitex-with-gofly",
        "source": "docs/reference/framework-gap-adopter-proof.json",
        "example": "examples/migration-proof/kitex-with-gofly",
        "gate": "make rpc-boundary-check",
        "rollbackAction": "Route latency-critical methods back to Kitex and retain gofly for REST ingress or governance surfaces.",
        "supportBundleAction": "Attach gofly bug --json with RPC boundary, resolver, balancer, stream, trace, auth, and benchmark evidence before escalating."
      }
    ],
    "dashboardEvidence": [
      "dxSupportBundle.remediationHandoff.schema",
      "dxSupportBundle.remediationHandoff.aiflowTask",
      "dxSupportBundle.troubleshootingAdoptionLoop",
      "releaseAdoptionContract.supplyChainEnforcementCount",
      "generatedUpgradeDryRun.profileCount",
      "benchmark.adopterPerformanceContract"
    ],
    "aiflowQueuePolicy": {
      "taskPrefix": "GOFLY-GOV-10P9-09",
      "supersedes": [
        "GOFLY-GOV-10R7-09"
      ],
      "allowed": [
        "queue remediation tasks",
        "run diagnostic commands",
        "produce patch plans",
        "produce bounded failure reports"
      ],
      "forbidden": [
        "git commit",
        "git push",
        "modify docs/superpowers/",
        "stage runtime state"
      ],
      "completionGate": "make dx-troubleshooting-check",
      "commitOwner": "human-or-current-agent"
    },
    "nextActionPolicy": "Every remediation row must identify a source command, stable fields, nextActionSource, dashboard evidence, adopter action, gate, and rollback or handoff boundary before aiflow can queue work."
  },
  "docs": [
    "docs/reference/cli-json-contracts.md",
    "docs/operations/troubleshooting.md"
  ]
}
