        "cmd/gofly/internal/command/idl_test.go"
      ],
      "evidence": [
        "name-from-filename",
        "go_opt",
        "go-grpc_opt",
        "go_grpc_opt",
        "warnNoopFlag"
      ],
      "gate": "go test -shuffle=on ./cmd/gofly/internal/command -run Test.*Goctl",
      "rollbackNote": "Keep goctl-style flags as accepted compatibility inputs and warn on no-op behavior instead of changing positional parsing semantics."
    },
    {
      "id": "api-tooling-compatibility",
      "status": "implemented",
      "implementation": [
        "cmd/gofly/internal/command/api_format_command.go",
        "cmd/gofly/internal/command/api_import_command.go",
        "cmd/gofly/internal/command/api_route_command.go",
        "cmd/gofly/internal/command/api_diff_command.go",
        "cmd/gofly/internal/generator/api_codegen.go"
      ],
      "tests": [
        "cmd/gofly/internal/command/idl_test.go",
        "cmd/gofly/internal/generator/idl_test.go"
      ],
      "evidence": [
        "api format",
        "api import",
        "api route",
        "api diff",
        "unsupported api diff format",
        "unsupported api route format"
      ],
      "gate": "go test -shuffle=on ./cmd/gofly/internal/command -run TestAPI",
      "rollbackNote": "Preserve existing api route and api diff format semantics; do not add unrelated validation or JSON envelope behavior."
    },
    {
      "id": "generated-version-fixtures",
      "status": "implemented",
      "implementation": [
        "testdata/generated-compat/matrix.json",
        "docs/reference/generated-version-compat.md",
        "docs/reference/generated-upgrade-dry-run.json"
      ],
      "tests": [
        "bin/scripts/check-generated-version-compat.sh",
        "bin/scripts/check-generated-upgrade-dry-run.sh"
