      "tests": [
        "cmd/gofly/internal/generator/service_scaffold_test.go",
        "cmd/gofly/internal/command/ai_helpers_test.go"
      ],
      "evidence": [
        "filepath.Join(\"internal\", \"routes\", \"routes.go\")",
        "filepath.Join(\"internal\", \"handler\", \"routes.go\")",
        "gozero profile should not include legacy file",
        "\"{{.Module}}/internal/routes\""
      ],
      "gate": "make test-generated-matrix",
      "rollbackNote": "Keep default generated routes aggregated under internal/routes while gozero-compatible scaffolds retain goctl-style handler routing."
    },
    {
      "id": "multi-language-client-generation",
      "status": "planned",
      "implementation": [],
      "tests": [],
      "promotionCriteria": [
        "define supported client languages and output contracts",
        "add generated client fixtures for old, current, and future API inputs",
        "verify generated clients in isolated temporary projects",
        "add compatibility notes and rollback guidance"
      ],
      "gate": "make goctl-generator-compat-check",
      "rollbackNote": "Keep client generation scoped to current Go artifacts until language-specific compile and compatibility gates exist."
    }
  ],
  "releaseGates": [
    "make goctl-generator-compat-check",
    "make generated-version-compat-check",
    "make generated-upgrade-dry-run-check",
    "make test-generated-matrix"
  ]
