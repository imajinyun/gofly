{
  "schema": "gofly.goctl_generator_compatibility.v1",
  "sourceOfTruth": [
    "docs/reference/generated-upgrade-dry-run.json",
    "testdata/generated-compat/matrix.json",
    "docs/reference/migration-fidelity-matrix.json"
  ],
  "acceptanceGate": "make goctl-generator-compat-check",
  "compatibilityBoundaries": {
    "noNewJSONEnvelopeFlags": true,
    "apiRouteAndDiffFormatValidationUnchanged": true,
    "positionalPluginAndMiddlewareNamesRemainNames": true,
    "generatedProjectDependenciesStayInGeneratedGoMod": true,
    "runtimeArtifactsRemainVolatile": true
  },
  "statusPolicy": {
    "implemented": "Capability has repository code or fixtures, tests, adopter documentation, and a gate.",
    "planned": "Capability is a known goctl-alignment target and must not be advertised as supported until code, tests, examples, and gates land together."
  },
  "capabilities": [
    {
      "id": "gozero-compatible-profile",
      "status": "implemented",
      "implementation": [
        "cmd/gofly/internal/generator/service_profile.go",
        "cmd/gofly/internal/generator/service_scaffold_ir.go",
        "cmd/gofly/internal/command/new_shared.go"
      ],
      "tests": [
        "cmd/gofly/internal/generator/service_scaffold_test.go",
        "cmd/gofly/internal/command/idl_test.go"
      ],
      "evidence": [
        "ProfileGoZeroCompatible",
        "goctl-layout",
        "filepath.Join(\"internal\", \"handler\", \"routes.go\")",
        "filepath.Join(\"internal\", \"logic\", \"pinglogic.go\")",
        "filepath.Join(\"internal\", \"svc\", \"servicecontext.go\")",
        "filepath.Join(\"internal\", \"types\", \"types.go\")"
      ],
      "gate": "go test -shuffle=on ./cmd/gofly/internal/generator -run TestBuildServiceScaffoldIRGoZeroProfileUsesLayeredArtifacts",
      "rollbackNote": "Use the default gofly-ai profile or pin the previous generated project when gozero-compatible layered files drift."
    },
    {
      "id": "goctl-compatible-flags",
      "status": "implemented",
