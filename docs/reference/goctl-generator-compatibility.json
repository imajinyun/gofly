        "current",
        "future",
        "deterministic-repeat-generation",
        "compatible-addition",
        "breaking-candidate"
      ],
      "gate": "make generated-version-compat-check",
      "rollbackNote": "Pin the previous generator version when old, current, or future fixtures stop generating, compiling, or reporting explainable diffs."
    },
    {
      "id": "upgrade-diff-contract",
      "status": "implemented",
      "implementation": [
        "docs/reference/generated-upgrade-dry-run.json",
        "docs/reference/migration-fidelity-matrix.json",
        "cmd/gofly/internal/command/upgrade.go"
      ],
      "tests": [
        "bin/scripts/check-generated-upgrade-dry-run.sh",
        "cmd/gofly/internal/command/ai_helpers_test.go"
      ],
      "evidence": [
        "diffReportContract",
        "migrationFidelityMatrix",
        "upgradeRehearsal",
        "DiffCommand",
        "rollbackNote"
      ],
      "gate": "make generated-upgrade-dry-run-check",
      "rollbackNote": "Treat unclassified generated diffs as breaking candidates until a migration note or rollback note explains the change."
    },
    {
      "id": "route-layout-boundary",
      "status": "implemented",
      "implementation": [
        "cmd/gofly/internal/generator/service_profile.go",
