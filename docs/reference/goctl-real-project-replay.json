  "diffContract": {
    "repeatGeneration": "Each matrix fixture replayed twice in independent temporary directories must produce the same generated artifact set and stable content hash for tracked artifacts.",
    "diffReport": "Replay diff reports must classify deterministic repeat output separately from compatible additions, generated cache template changes, and breaking candidates.",
    "rollbackNote": "If replay changes are unclassified or generated projects stop compiling, pin the previous goctl-compatible generator profile and keep the previous model/cache template until a migration note explains the diff.",
    "categories": [
      "deterministic-repeat-generation",
      "compatible-addition",
      "generated-cache-template",
      "breaking-candidate"
    ]
  },
  "smoke": {
    "goTest": "Replay creates an isolated temporary module and runs go test ./... after replacing github.com/imajinyun/gofly with the local checkout.",
    "repeatReplay": "Every fixture replay runs twice and compares tracked artifact hashes so generated output is deterministic.",
    "rootDependencyPolicy": "Generated-only model/cache dependencies must stay in the replayed project's go.mod and must not be added to the gofly root go.mod."
  },
  "releaseGates": [
    "make goctl-real-project-replay-check",
    "make goctl-generator-compat-check",
    "make generated-version-compat-check"
  ],
  "status": {
    "goctlCommandSurface": "unchanged",
    "fixtureMatrixDepth": "transitive-import-comments-tags-nested-model",
    "modelCacheTemplateDepth": "covered-by-three-fixture-replay-matrix"
  }
}
