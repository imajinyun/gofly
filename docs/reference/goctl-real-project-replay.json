{
  "schema": "gofly.goctl_real_project_replay.v1",
  "purpose": "Make goctl alignment adoption-proof by replaying a matrix of realistic go-zero/goctl-style project fixtures through gofly generators, deterministic diff classification, generated model/cache output, .api import resolution, and temporary generated-module smoke.",
  "sourceOfTruth": [
    "docs/reference/goctl-generator-compatibility.json",
    "docs/reference/generated-upgrade-dry-run.json",
    "testdata/goctl-replay/orderservice/replay.json",
    "testdata/goctl-replay/inventoryservice/replay.json",
    "testdata/goctl-replay/billingservice/replay.json"
  ],
  "acceptanceGate": "make goctl-real-project-replay-check",
  "scope": {
    "referenceFramework": "go-zero goctl service layout and model workflow",
    "fixtureClass": "realistic-gozero-goctl-project-matrix",
    "expandsCLICommandSurface": false,
    "policy": "This replay closes adoption trust gaps with fixture replay, not new commands or flags."
  },
  "matrix": {
    "minimumFixtures": 3,
    "requiredCapabilities": [
