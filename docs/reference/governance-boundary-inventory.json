  "aiflowTasks": [
    {
      "id": "GOFLY-P11-1-RPC-TIER1-PROMOTION-REVIEW",
      "round": 1,
      "title": "RPC Tier 1 promotion review",
      "objective": "Review whether P10 RPC release-train evidence is sufficient to promote unary or stream surfaces toward Tier 1 while keeping latency parity claims conservative.",
      "deliverable": "P11 promotion review evidence for unary, server stream, client stream, bidi stream, resolver, balancer, deadline, retry, auth, tracing, benchmark budget, Kitex coexistence, and rollback status.",
      "gate": "make rpc-boundary-check",
      "commitPolicy": "commit after RPC promotion review evidence and rpc-boundary-check pass"
    },
    {
      "id": "GOFLY-P11-2-GENERATED-PROJECT-LIVE-UPGRADE",
      "round": 2,
      "title": "Generated project live upgrade",
      "objective": "Run generated project compatibility fixtures against a realistic adopter upgrade path and keep generated-project-only dependencies outside the root module.",
      "deliverable": "P11 live upgrade proof for old, current, and future profiles with classified diffs, temporary project compile/test evidence, dependency boundary notes, and rollback actions.",
      "gate": "make generated-upgrade-dry-run-check",
      "commitPolicy": "commit after generated upgrade evidence and generated-upgrade-dry-run-check pass"
    },
    {
      "id": "GOFLY-P11-3-CLOUD-NATIVE-HOSTED-PROOF",
      "round": 3,
      "title": "Cloud-native hosted proof",
      "objective": "Prepare hosted CI proof for Docker-backed reference app, Helm rendering, kube policy validation, and release evidence gates when required tools are available.",
      "deliverable": "P11 hosted proof contract for Docker, Helm, kubeconform or kubeval, Trivy, release evidence, fallback reasons, and operator rollback notes.",
      "gate": "make p1-growth-check",
      "commitPolicy": "commit after hosted cloud-native proof gates pass or explicit environment-limited fallback evidence is recorded"
    }
  ],
