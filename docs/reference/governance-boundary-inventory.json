  "aiflowTasks": [
    {
      "id": "GOFLY-P12-1-RPC-BENCHMARK-BUDGET-PROMOTION",
      "round": 1,
      "title": "RPC benchmark budget promotion hold",
      "objective": "Review the RPC unary and stream benchmark rows against release-train, allocation, current trend, baseline, and rollback evidence before promoting any budget to blocking mode.",
      "deliverable": "P12 promotion hold evidence for unary, server stream, client stream, bidi stream, tracked benchmark exclusion, allocation blockers, forbidden performance claims, and rollback actions.",
      "gate": "make rpc-boundary-check",
      "verification": [
        "make rpc-boundary-check",
        "make bench-regression-check"
      ],
      "commit": "7d0b69a",
      "commitPolicy": "commit after RPC budget promotion hold evidence, rpc-boundary-check, and bench-regression-check pass"
    },
    {
      "id": "GOFLY-P12-2-GENERATED-UPGRADE-REAL-BRANCH",
      "round": 2,
      "title": "Generated upgrade real branch replay",
      "objective": "Convert generated project live upgrade proof into a real adopter branch replay contract with classified repeat-generation diffs and ignored runtime worktrees.",
      "deliverable": "P12 real branch replay evidence for old, current, and future profiles, real branch preflight, runtime artifact policy, diff classification, and rollback actions.",
      "gate": "make generated-upgrade-dry-run-check",
      "verification": [
        "make generated-upgrade-dry-run-check"
      ],
      "commit": "d99c690",
      "commitPolicy": "commit after generated real branch replay evidence and generated-upgrade-dry-run-check pass"
    },
    {
      "id": "GOFLY-P12-3-HOSTED-CLOUD-NATIVE-LIVE-CI",
      "round": 3,
      "title": "Hosted cloud-native live CI",
      "objective": "Turn cloud-native live render validation into a hosted release-blocking CI job with artifact upload, release prerequisites, and drift checks.",
      "deliverable": "P12 hosted live CI proof for Helm, kubeconform or kubeval, release prerequisite wiring, artifact contracts, and CI drift validation.",
      "gate": "make cloud-native-render-check",
      "verification": [
        "make cloud-native-render-check",
        "make ci-required-check-evidence-check",
        "make required-checks-drift-check"
      ],
      "commit": "155fd18",
      "commitPolicy": "commit after hosted cloud-native live CI evidence, render check, CI required check evidence, and required-checks drift pass"
    }
  ],
