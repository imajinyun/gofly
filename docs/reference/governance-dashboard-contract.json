{
  "schema": "gofly.governance_dashboard_contract.v1",
  "sourceReport": "gofly.governance_report.v1",
  "acceptanceGate": "make governance-report-check",
  "summaryFields": [
    "release.readinessScore.status",
    "release.readinessScore.score",
    "releaseEvidenceConsumption.driftClosure.driftGate",
    "releaseEvidenceConsumption.driftClosure.requiredEvidenceCount",
    "releaseEvidenceConsumption.driftClosure.releasePrerequisiteCoverage",
    "releaseEvidenceConsumption.tagCIClosure.stageCount",
    "releaseEvidenceConsumption.tagCIClosure.requiredLocalGates",
    "ciRequiredChecks.p13HostedReleaseSupplyChainClosure.status",
    "ciRequiredChecks.p13HostedReleaseSupplyChainClosure.aiflowTask",
    "ciRequiredChecks.p13HostedReleaseSupplyChainClosure.artifactFamilyCount",
    "releaseAdoptionContract.decisionCount",
    "releaseAdoptionContract.riskClassCounts",
    "releaseAdoptionContract.tagCIClosureRowCount",
    "releaseAdoptionContract.supplyChainEnforcementCount",
    "dashboard.releaseDashboardConsumption.schema",
    "dashboard.releaseDashboardConsumption.status",
    "dashboard.releaseDashboardConsumption.aiflowTask",
    "dashboard.releaseDashboardConsumption.stableFieldCount",
    "dashboard.releaseDashboardConsumption.consumerRowCount",
    "dashboard.releaseDashboardConsumption.requiredGateCount",
    "apiSurface.tiers",
    "benchmark.regressionGate",
    "benchmark.regressionReport",
    "benchmark.trendSummaryStatus",
    "benchmark.surfacePolicy.surfaceCount",
    "benchmark.surfacePolicy.statusCounts",
    "benchmark.surfacePolicy.adopterPerformanceContract.blockingSurfaceCount",
    "benchmark.surfacePolicy.adopterPerformanceContract.reportOnlySurfaceCount",
    "benchmark.surfacePolicy.adopterPerformanceContract.unsupportedSurfaceCount",
    "coverage.ratchet",
    "coverageTrend.policy.blockingGate",
    "security.gosec.blockingGate",
    "security.govulncheck.blockingGate",
    "productionDefaults.capabilityCount",
    "productionDefaults.missingAssets",
    "runtimeSLO.operatorDrillCount",
    "runtimeSLO.incidentRehearsalCount",
    "dxSupportBundle.surfaceCount",
    "dxSupportBundle.remediationHintCount",
    "dxSupportBundle.remediationHandoff.schema",
    "dxSupportBundle.remediationHandoff.aiflowTask",
    "dxSupportBundle.remediationHandoff.owner",
    "dxSupportBundle.remediationLoopContract.schema",
    "dxSupportBundle.remediationLoopContract.sourceContractCount",
    "dxSupportBundle.remediationLoopContract.migrationRouteCount",
    "dxSupportBundle.p13CliDoctorTroubleshootingLoop.status",
    "dxSupportBundle.p13CliDoctorTroubleshootingLoop.aiflowTask",
    "governanceConvergence.taskCount",
    "governanceConvergence.ignoredRuntimePathCount",
    "aiflow.status",
    "aiflow.summary",
    "dashboard.productionReadinessScorecard.surfaceCount",
    "dashboard.productionReadinessScorecard.riskClassCounts",
    "dashboard.evidenceTraceability.claimCount"
  ],
  "releaseReadiness": {
    "schema": "gofly.release_readiness_score.v1",
    "requiredStatus": "ready",
    "minimumScore": 100,
    "source": "docs/releases/readiness-score.json"
  },
  "releaseEvidenceConsumption": {
    "schema": "gofly.release_evidence_consumption.v1",
    "source": "docs/releases/evidence-consumption.json",
    "sourceOfTruth": "docs/releases/evidence-index.json",
    "acceptanceGate": "make governance-report-check",
    "driftGate": "make required-checks-drift-check",
    "reportField": "releaseEvidenceConsumption.driftClosure",
    "requiredCheckSource": "docs/reference/ci-required-check-evidence.json",
    "requiredDashboardFields": [
      "releaseEvidenceConsumption.driftClosure.driftGate",
      "releaseEvidenceConsumption.driftClosure.requiredEvidenceCount",
      "releaseEvidenceConsumption.driftClosure.releasePrerequisiteCoverage",
      "releaseEvidenceConsumption.tagCIClosure.stageCount",
      "releaseEvidenceConsumption.tagCIClosure.requiredLocalGates"
    ]
  },
  "releaseAdoptionContract": {
    "schema": "gofly.release_adoption_contract.v1",
    "source": "docs/releases/adoption-contract.json",
    "sourceOfTruth": "docs/releases/evidence-consumption.json",
    "acceptanceGate": "make governance-report-check",
    "reportField": "releaseAdoptionContract",
    "requiredDecisions": [
      "upgrade",
      "publish",
      "block",
      "rollback"
    ],
    "requiredDashboardFields": [
      "releaseAdoptionContract.decisionCount",
      "releaseAdoptionContract.riskClassCounts",
      "releaseAdoptionContract.tagCIClosureRowCount"
    ]
  },
  "releaseDashboardConsumption": {
    "schema": "gofly.release_dashboard_consumption.v1",
    "aiflowTask": "GOFLY-P10-9-RELEASE-DASHBOARD-CONSUMPTION",
    "status": "blocking-contract",
    "source": "docs/reference/governance-dashboard-contract.json",
    "sourceReport": "gofly.governance_report.v1",
    "reportField": "dashboard.releaseDashboardConsumption",
    "acceptanceGate": "make governance-report-check",
    "driftGate": "make required-checks-drift-check",
    "owner": "human-or-current-agent",
    "policy": "Adopter-facing release dashboards must consume stable fields only. Release readiness, API tiers, security gates, coverage ratchets, benchmark ratchets, and aiflow task status must stay visible in the governance report before release promotion or upgrade decisions.",
    "requiredGates": [
      "make governance-report-check",
      "make required-checks-drift-check"
    ],
    "requiredStableFields": [
      "release.readinessScore.status",
      "release.readinessScore.score",
      "apiSurface.tiers",
      "security.gosec.blockingGate",
      "security.govulncheck.blockingGate",
      "coverage.ratchet",
      "coverageTrend.policy.blockingGate",
      "benchmark.regressionGate",
      "benchmark.surfacePolicy.adopterPerformanceContract.blockingSurfaceCount",
      "benchmark.surfacePolicy.adopterPerformanceContract.reportOnlySurfaceCount",
      "benchmark.surfacePolicy.adopterPerformanceContract.unsupportedSurfaceCount",
      "aiflow.status",
      "aiflow.summary"
    ],
    "consumerRows": [
      {
        "id": "release-readiness",
        "sourceReportFields": [
          "release.readinessScore.status",
          "release.readinessScore.score"
        ],
        "gate": "make governance-report-check",
        "adopterAction": "promote or upgrade only when the release readiness status is ready and the score reaches the configured release threshold",
        "rollbackOrEscalation": "block release promotion and keep the previous published artifact when readiness score, evidence components, or report fields drift"
      },
      {
        "id": "api-tier-consumption",
        "sourceReportFields": [
          "apiSurface.tiers"
        ],
        "gate": "make stable-surface-check",
        "adopterAction": "consume Tier 0 and Tier 1 surfaces as stable only after the stable surface gate and deprecation evidence remain green",
        "rollbackOrEscalation": "pin the previous API surface and require migration notes when tier rows, compatibility statements, or generated golden evidence drift"
      },
      {
        "id": "security-gate-consumption",
        "sourceReportFields": [
          "security.gosec.blockingGate",
          "security.govulncheck.blockingGate"
        ],
        "gate": "make governance-report-check",
        "adopterAction": "treat gosec and govulncheck gates as release blockers and review baselines before accepting dependency or external input changes",
        "rollbackOrEscalation": "block promotion until new security findings are fixed, justified with scoped exceptions, or downgraded with explicit risk ownership"
      },
      {
        "id": "coverage-ratchet-consumption",
        "sourceReportFields": [
          "coverage.ratchet",
          "coverageTrend.policy.blockingGate"
        ],
        "gate": "make coverage-trend-check",
        "adopterAction": "treat the coverage ratchet as the minimum non-regression contract and raise it only after full governance evidence stabilizes",
        "rollbackOrEscalation": "hold the release and restore coverage evidence when the ratchet drops, stale coverage artifacts appear, or blocking gates are bypassed"
      },
      {
        "id": "benchmark-ratchet-consumption",
        "sourceReportFields": [
          "benchmark.regressionGate",
          "benchmark.surfacePolicy.adopterPerformanceContract.blockingSurfaceCount",
          "benchmark.surfacePolicy.adopterPerformanceContract.reportOnlySurfaceCount",
          "benchmark.surfacePolicy.adopterPerformanceContract.unsupportedSurfaceCount"
        ],
        "gate": "make bench-regression-check",
        "adopterAction": "block only promoted allocation budget regressions and keep weak latency or unsupported gateway/cache rows report-only until evidence matures",
        "rollbackOrEscalation": "revert the hot-path change or keep the surface candidate when benchmark evidence, sample counts, or promotion rules are incomplete"
      },
      {
        "id": "aiflow-task-status-consumption",
        "sourceReportFields": [
          "aiflow.status",
          "aiflow.summary"
        ],
        "gate": "make governance-report-check",
        "adopterAction": "use the aiflow status and summary as release dashboard context only; never commit local .aiflow or .harness runtime state",
        "rollbackOrEscalation": "continue with explicit unavailable status when local aiflow state is absent, and block only if committed dashboard fields disappear"
      }
    ],
    "runtimeStatePolicy": "Local .aiflow, .harness, .tmp-test, .trae, coverage.out, bench/regression-report.json, and docs/superpowers artifacts are dashboard inputs or generated evidence only and must stay ignored.",
    "commitPolicy": "The P10 dashboard task is completed by the current agent or human only after governance-report-check and required-checks-drift-check pass; runtime state must not be staged."
  },
  "apiTiers": {
    "source": "docs/reference/api-surface.md",
    "gate": "make stable-surface-check",
    "minimumTierCount": 3
  },
  "benchmarkRatchet": {
    "source": "bench/budget-ratchet.json",
    "gate": "make bench-regression-check",
    "adopterPerformanceContract": {
      "schema": "gofly.benchmark_adopter_performance_contract.v1",
      "reportField": "benchmark.adopterPerformanceContract",
      "requiredSurfaceCounts": {
        "blocking": 2,
        "reportOnly": 2,
        "unsupported": 2
      },
      "requiredDashboardFields": [
        "benchmark.surfacePolicy.adopterPerformanceContract.blockingSurfaceCount",
        "benchmark.surfacePolicy.adopterPerformanceContract.reportOnlySurfaceCount",
        "benchmark.surfacePolicy.adopterPerformanceContract.unsupportedSurfaceCount"
      ]
    },
    "requiredFields": [
      "schema",
      "trackedBenchmarks",
      "latencyPolicy",
      "allocationPolicy",
      "rpcPolicy",
      "surfacePolicy"
    ]
  },
  "coverage": {
    "source": "docs/reference/coverage-trend.json",
    "gate": "make coverage-trend-check",
    "ratchetVar": "COVERAGE_RATCHET"
  },
  "security": {
    "gosecGate": "make gosec",
    "govulncheckGate": "make govulncheck",
    "baseline": "bin/scripts/gosec-exception-baseline.json"
  },
  "productionDefaults": {
    "schema": "gofly.production_defaults.v1",
    "source": "docs/reference/runtime-slo.json",
    "gate": "make runtime-slo-check",
    "reportGate": "make governance-report-check",
    "requiredAssetMinimum": 9,
    "requiredCapabilities": [
      "health-probes",
      "metrics",
      "traces",
      "structured-logs",
      "admin-diagnostics",
      "profiles",
      "rollback-drills"
    ]
  },
  "governanceConvergence": {
    "schema": "gofly.governance_boundary_inventory.v1",
    "source": "docs/reference/governance-boundary-inventory.json",
    "gate": "make governance-boundary-inventory-check",
    "finalGate": "make governance-10-rounds",
    "requiredTaskCount": 3,
    "requiredActiveBatch": "GOFLY-P18",
    "latestCompletedBatch": "GOFLY-P17",
    "activeRoadmap": "docs/reference/governance-p18-roadmap.json",
    "requiredIgnoredRuntimePaths": [
      "docs/superpowers/",
      ".aiflow/",
      ".harness/",
      ".tmp-test/",
      ".trae/",
      "coverage.out"
    ]
  },
  "aiflow": {
    "source": ".aiflow/store.json",
    "fallbackSource": ".harness/store.json",
    "requiredStatusField": "status",
    "requiredSummaryField": "summary",
    "requiredRuntimePolicy": "runtime state is consumed as ignored local evidence and must never be committed"
  },
  "aiNativeWorkflow": {
    "schema": "gofly.dx_support_bundle.v1",
    "source": "docs/reference/dx-support-bundle.json",
    "controlPlaneSource": "docs/case-studies/ai-control-plane-drift.md",
    "gate": "make dx-troubleshooting-check",
    "reportGate": "make governance-report-check",
    "requiredCommands": [
      "gofly doctor --json",
      "gofly bug --json",
      "gofly release check --json --strict",
      "gofly ai new --json --apply --verify"
    ],
    "requiredWorkflowSteps": [
      "run gofly doctor --json",
      "run gofly release check --json --strict",
      "run gofly bug --json",
      "attach generated project verification failure reports when available"
    ],
    "requiredStableFields": [
      "nextActions",
      "supportBundle",
      "error.remediation",
      "data.verification",
      "data.nextActions"
    ],
    "requiredHandoffSchema": "gofly.remediation_handoff.v1",
    "requiredCommitOwner": "human-or-current-agent",
    "handoffReportField": "dxSupportBundle.remediationHandoff",
    "remediationLoopReportField": "dxSupportBundle.remediationLoopContract",
    "requiredHandoffGates": [
      "make dx-troubleshooting-check",
      "make governance-report-check",
      "go test -shuffle=on ./cmd/gofly/internal/command -run 'TestCLIJSONContractGoldens|TestCLIJSONErrorEnvelopeGolden'"
    ]
  },
  "productionReadinessScorecard": {
    "schema": "gofly.production_readiness_scorecard.v1",
    "source": "docs/reference/governance-dashboard-contract.json",
    "gate": "make governance-report-check",
    "requiredRiskClasses": [
      "production-ready",
      "candidate",
      "report-only",
      "rollback-required"
    ],
    "surfaces": [
      {
        "id": "stable-api-surface",
        "riskClass": "production-ready",
        "source": "docs/reference/api-surface.md",
        "gate": "make stable-surface-check",
        "adopterAction": "depend on Tier 0 and Tier 1 surfaces only after stable-surface and deprecation lifecycle gates pass"
      },
      {
        "id": "generated-output",
        "riskClass": "production-ready",
        "source": "docs/reference/generated-upgrade-dry-run.json",
        "gate": "make generated-upgrade-dry-run-check",
        "adopterAction": "regenerate into a temporary project and review classified diffs before updating generated services"
      },
      {
        "id": "runtime-operations",
        "riskClass": "production-ready",
        "source": "docs/reference/runtime-slo.json",
        "gate": "make runtime-slo-check",
        "adopterAction": "verify health, readiness, metrics, traces, resilience drills, and rollback decisions before production rollout"
      },
      {
        "id": "cloud-native-deployment",
        "riskClass": "candidate",
        "source": "docs/reference/cloud-native-policy-conformance.json",
        "gate": "make cloud-native-render-check",
        "adopterAction": "render Helm and Kustomize assets locally and inspect fallback status before treating deployment policy as enforced"
      },
      {
        "id": "security-and-dependencies",
        "riskClass": "production-ready",
        "source": "docs/reference/dependency-upgrade-evidence.json",
        "gate": "make dependency-upgrade-evidence-check",
        "adopterAction": "verify module checksums, vulnerabilities, root dependency policy, and dependency ownership before upgrading"
      },
      {
        "id": "performance-budget",
        "riskClass": "report-only",
        "source": "bench/budget-ratchet.json",
        "gate": "make bench-regression-check",
        "adopterAction": "treat latency comparison as trend evidence and block only allocation budgets promoted by the ratchet policy"
      },
      {
        "id": "release-evidence",
        "riskClass": "production-ready",
        "source": "docs/releases/readiness-score.json",
        "gate": "make governance-report-check",
        "adopterAction": "promote releases only when readiness score is ready and required evidence artifacts are present"
      },
      {
        "id": "adoption-risk",
        "riskClass": "rollback-required",
        "source": "docs/reference/adoption-risk-register.json",
        "gate": "make framework-gap-check",
        "adopterAction": "pin, rollback, or block promotion when a surface is marked rollback-required or a promotion gate fails"
      },
      {
        "id": "required-checks",
        "riskClass": "production-ready",
        "source": "docs/reference/ci-required-check-evidence.json",
        "gate": "make required-checks-drift-check",
        "adopterAction": "require release prerequisite drift, branch protection, local gate, and artifact evidence to stay aligned"
      },
      {
        "id": "plugin-ecosystem",
        "riskClass": "candidate",
        "source": "docs/reference/plugin-conformance.md",
        "gate": "make plugin-conformance-check",
        "adopterAction": "accept only plugins that pass manifest, digest, permission, compatibility, and failure isolation checks"
      },
      {
        "id": "ai-native-support-bundle",
        "riskClass": "production-ready",
        "source": "docs/reference/dx-support-bundle.json",
        "gate": "make dx-troubleshooting-check",
        "adopterAction": "collect doctor, release, support bundle, generated verification, remediation handoff, and control-plane evidence before asking agents or maintainers to diagnose failures"
      }
    ]
  },
  "evidenceTraceability": {
    "schema": "gofly.evidence_traceability.v1",
    "source": "docs/reference/governance-dashboard-contract.json",
    "gate": "make governance-report-check",
    "claims": [
      {
        "id": "stable-surface-contract",
        "claim": "Tier 0 and Tier 1 adoption surfaces are machine checked before release.",
        "sourceManifest": "docs/reference/governance-dashboard-contract.json",
        "reportField": "apiSurface.tiers",
        "gate": "make stable-surface-check",
        "riskClass": "production-ready",
        "rollbackOrEscalation": "pin the previous release or block promotion when stable-surface evidence is incomplete"
      },
      {
        "id": "release-readiness",
        "claim": "Release promotion requires complete evidence and a ready score.",
        "sourceManifest": "docs/releases/readiness-score.json",
        "reportField": "release.readinessScore.status",
        "gate": "make governance-report-check",
        "riskClass": "production-ready",
        "rollbackOrEscalation": "block release promotion when readiness score is not ready or evidence artifacts are missing"
      },
      {
        "id": "release-evidence-drift-closure",
        "claim": "Release evidence consumption is mapped to required-check drift so tag promotion cannot silently lose adopter evidence.",
        "sourceManifest": "docs/releases/evidence-consumption.json",
        "reportField": "releaseEvidenceConsumption.driftClosure",
        "gate": "make required-checks-drift-check",
        "riskClass": "production-ready",
        "rollbackOrEscalation": "block tag promotion until every release evidence id maps to a release prerequisite or explicit release artifact producer"
      },
      {
        "id": "release-tag-ci-closure",
        "claim": "Release tag CI ties snapshot, checksums, SBOM, Docker digest, Trivy, provenance, required checks, publish decisions, block decisions, and rollback into one auditable chain.",
        "sourceManifest": "docs/releases/evidence-consumption.json",
        "reportField": "releaseEvidenceConsumption.tagCIClosure",
        "gate": "make governance-report-check",
        "riskClass": "production-ready",
        "rollbackOrEscalation": "block tag promotion until tag CI closure stages and adoption rows agree on evidence, gates, publish decisions, block decisions, and rollback"
      },
      {
        "id": "required-checks-drift",
        "claim": "Release prerequisites and required checks are protected from silent drift.",
        "sourceManifest": "docs/reference/ci-required-check-evidence.json",
        "reportField": "ciRequiredChecks.releasePrerequisiteCount",
        "gate": "make required-checks-drift-check",
        "riskClass": "production-ready",
        "rollbackOrEscalation": "restore the missing required check or block tag promotion until branch protection and release needs match"
      },
      {
        "id": "runtime-operations",
        "claim": "Runtime operation evidence covers golden signals and operator drills.",
        "sourceManifest": "docs/reference/runtime-slo.json",
        "reportField": "runtimeSLO.signalCount",
        "gate": "make runtime-slo-check",
        "riskClass": "production-ready",
        "rollbackOrEscalation": "hold rollout and follow operator drill rollback guidance when runtime SLO evidence is incomplete"
      },
      {
        "id": "generated-upgrade-dry-run",
        "claim": "Generated project upgrades are rehearsed with deterministic diff categories and rollback notes.",
        "sourceManifest": "docs/reference/generated-upgrade-dry-run.json",
        "reportField": "generatedUpgradeDryRun.profileCount",
        "gate": "make generated-upgrade-dry-run-check",
        "riskClass": "production-ready",
        "rollbackOrEscalation": "pin the generator profile and block regeneration when dry-run repeatability or rollback notes fail"
      },
      {
        "id": "dependency-ownership",
        "claim": "Dependency upgrades have owner, boundary, evidence, and rollback contracts.",
        "sourceManifest": "docs/reference/dependency-upgrade-evidence.json",
        "reportField": "ciRequiredChecks.driftGate",
        "gate": "make dependency-upgrade-evidence-check",
        "riskClass": "production-ready",
        "rollbackOrEscalation": "revert or pin the dependency when ownership evidence, vulnerability scans, or integration delegation fails"
      },
      {
        "id": "performance-budget",
        "claim": "Performance claims are limited to tracked benchmark evidence and ratcheted budgets.",
        "sourceManifest": "bench/budget-ratchet.json",
        "reportField": "benchmark.regressionGate",
        "gate": "make bench-regression-check",
        "riskClass": "report-only",
        "rollbackOrEscalation": "treat latency rows as report-only and block only allocation budgets promoted by the ratchet"
      },
      {
        "id": "production-readiness-scorecard",
        "claim": "Production readiness is summarized by risk class across adoption surfaces.",
        "sourceManifest": "docs/reference/governance-dashboard-contract.json",
        "reportField": "dashboard.productionReadinessScorecard.surfaceCount",
        "gate": "make governance-report-check",
        "riskClass": "candidate",
        "rollbackOrEscalation": "follow the surface-specific adopter action and block promotion when any required source or gate is missing"
      },
      {
        "id": "ai-native-support-workflow",
        "claim": "AI-native support workflows expose doctor, release, support bundle, generated failure, aiflow handoff, and control-plane remediation evidence as machine-readable contracts.",
        "sourceManifest": "docs/reference/dx-support-bundle.json",
        "reportField": "dxSupportBundle.remediationHandoff",
        "gate": "make dx-troubleshooting-check",
        "riskClass": "production-ready",
        "rollbackOrEscalation": "fall back to manual troubleshooting and block agent-driven remediation when nextActions, support bundle redaction, commit ownership, or control-plane evidence is missing"
      }
    ]
  },
  "outputs": [
    ".tmp-test/governance-report/governance-report.json",
    ".tmp-test/governance-report/governance-report.md"
  ]
}
