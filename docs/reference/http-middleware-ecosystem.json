{
  "schema": "gofly.http_middleware_ecosystem.v1",
  "status": "blocking",
  "blockingGate": "make p1-growth-check",
  "smokeGate": "make examples-smoke",
  "migrationPolicy": {
    "referenceFrameworks": [
      "Gin",
      "go-zero"
    ],
    "adopterAction": "Use the middleware matrix as the migration checklist before switching HTTP traffic from Gin or go-zero services.",
    "openAPIVisibilityRequired": true,
    "controlPlaneVisibilityRequired": true,
    "rollbackOrEscalation": "Keep the existing Gin or go-zero middleware chain active until JWT, CORS, CSRF, session, Prometheus, OpenTelemetry, SSE, WebSocket, OpenAPI, and smoke gates pass locally."
  },
  "exampleModules": [
    "examples/middlewares",
    "examples/middleware-demo",
    "examples/http-middleware"
  ],
  "capabilities": [
    {
      "id": "jwt",
      "name": "JWT",
      "category": "auth",
      "ownerDocs": [
        "examples/http-middleware/README.md",
        "examples/middlewares/jwt.go"
      ],
      "examples": [
        "examples/http-middleware",
        "examples/middlewares"
      ],
      "smokeGates": [
        "go test -C examples/http-middleware ./...",
        "go test -C examples/middlewares ./..."
      ],
      "migration": {
        "from": [
          "Gin auth middleware",
          "go-zero JWT middleware"
        ],
        "adopterAction": "Map bearer token validation to rest.BearerAuthMiddleware and expose the secured route in OpenAPI before switching traffic.",
        "rollbackOrEscalation": "Keep the previous auth middleware chain active when JWT validation, OpenAPI security metadata, or smoke tests fail."
      },
      "evidenceRefs": [
        {
          "path": "examples/http-middleware/main_test.go",
          "contains": [
            "JWT",
            "without JWT",
            "VerifyJWT"
          ]
        },
        {
          "path": "examples/middlewares/catalog.go",
          "contains": [
            "JWT",
            "JWTMiddleware"
          ]
        }
      ]
    },
    {
      "id": "cors",
      "name": "CORS",
      "category": "web-security",
      "ownerDocs": [
        "examples/http-middleware/README.md",
        "examples/middlewares/cors.go"
      ],
      "examples": [
        "examples/http-middleware",
        "examples/middlewares"
      ],
      "smokeGates": [
        "go test -C examples/http-middleware ./...",
        "go test -C examples/middlewares ./..."
      ],
      "migration": {
        "from": [
          "Gin CORS middleware",
          "go-zero CORS middleware"
        ],
        "adopterAction": "Port allowed origins, headers, methods, credentials, and exposed headers into rest.CORSConfig before switching browser traffic.",
        "rollbackOrEscalation": "Keep the previous CORS layer when preflight headers or credential behavior diverge from production samples."
      },
      "evidenceRefs": [
        {
          "path": "examples/http-middleware/main_test.go",
          "contains": [
            "Access-Control-Allow-Origin",
            "CORS"
          ]
        },
        {
          "path": "examples/middlewares/catalog.go",
          "contains": [
            "CORS",
            "CORSMiddleware"
          ]
        }
      ]
    },
    {
      "id": "csrf",
      "name": "CSRF",
      "category": "web-security",
      "ownerDocs": [
