{
  "schema": "gofly.openapi_invalid_request_smoke.v1",
  "status": "blocking",
  "blockingGate": "make openapi-validation-check",
  "runtimeEnvelope": {
    "type": "rest.ErrorResponse",
    "status": 400,
    "code": "invalid_argument"
  },
  "smokeCases": [
    {
      "id": "path-parse-failure",
      "surface": "path",
      "source": "ctx.PathValue and path tags",
      "expectedStatus": 400,
      "expectedCode": "invalid_argument",
      "gate": "go test -shuffle=on ./rest -run TestOpenAPIValidationEnvelopeRuntimeGolden_BitsUT",
      "evidenceRefs": [
        {
          "path": "rest/binding_test.go",
          "contains": [
            "path parse failure",
            "bind path field ID",
            "rest.ErrorResponse"
          ]
        },
        {
          "path": "rest/openapi_test.go",
          "contains": [
            "path",
            "JSONBodySchema"
          ]
        }
      ]
    },
    {
      "id": "query-validation-failure",
      "surface": "query",
      "source": "query tags and BindRequest",
      "expectedStatus": 400,
      "expectedCode": "invalid_argument",
      "gate": "go test -shuffle=on ./rest -run TestOpenAPIValidationEnvelopeRuntimeGolden_BitsUT",
      "evidenceRefs": [
        {
          "path": "rest/binding_test.go",
          "contains": [
            "query tag validation failure",
            "field Page failed min=1 validation",
            "ValidationFailuresOf"
          ]
        },
        {
          "path": "rest/openapi_test.go",
          "contains": [
            "query",
            "min=1,max=100"
          ]
        }
      ]
    },
    {
      "id": "header-validation-failure",
      "surface": "header",
