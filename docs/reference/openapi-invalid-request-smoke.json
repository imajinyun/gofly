      "evidenceRefs": [
        {
          "path": "rest/binding_test.go",
          "contains": [
            "header tag validation failure",
            "field Tenant failed required validation"
          ]
        },
        {
          "path": "rest/openapi_test.go",
          "contains": [
            "header",
            "required"
          ]
        }
      ]
    },
    {
      "id": "body-decode-failure",
      "surface": "body",
      "source": "JSON body binding",
      "expectedStatus": 400,
      "expectedCode": "invalid_argument",
      "gate": "go test -shuffle=on ./rest -run TestOpenAPIValidationEnvelopeRuntimeGolden_BitsUT",
      "evidenceRefs": [
        {
          "path": "rest/binding_test.go",
