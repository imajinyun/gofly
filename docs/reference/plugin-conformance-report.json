{
  "schema": "gofly.plugin_conformance_report.v1",
  "sourceOfTruth": "docs/reference/plugin-conformance.md",
  "aiflowTask": "GOFLY-P1-4-PLUGIN-CONFORMANCE-RUNNER",
  "acceptanceGate": "make plugin-conformance-check",
  "runner": {
    "mode": "make-target-json-report",
    "command": "make plugin-conformance-check",
    "reportConsumer": "release evidence and adopter plugin publishing review",
    "outputContract": "registry, manifest, digest, signature, permission, compatibility, malicious-path, and failure-isolation results are represented as stable JSON cases"
  },
  "adopterPublishingContract": {
    "schema": "gofly.plugin_adopter_publishing_contract.v1",
    "source": "docs/reference/plugin-conformance-report.json",
    "publishingUX": "docs/reference/plugin-publishing-ux.json",
    "dashboardReportField": "pluginAdoption.publishingConformance",
    "consumers": [
      "adopter",
      "plugin-publisher",
      "release-manager",
      "ci-agent"
    ],
    "acceptanceGates": [
      "make plugin-conformance-check",
      "go test -C examples/plugin-ecosystem ./...",
      "go run -C examples/plugin-ecosystem ."
    ],
    "policy": "Adopters may publish or install third-party plugins only after registry, manifest, digest, signature, permission, compatibility, malicious-path, and failure-isolation evidence all pass.",
    "publishBlockers": [
      {
        "id": "registry-or-manifest-invalid",
        "cases": [
          "registry-schema",
          "manifest-schema"
        ],
        "adopterAction": "Block publication when registry metadata, manifest fields, dry-run requirements, source, checksum, or permission declarations are incomplete.",
        "rollbackAction": "Keep the previous registry entry pinned until the publisher republishes a complete manifest and conformance report."
      },
      {
        "id": "protocol-incompatible",
        "cases": [
          "old-protocol",
          "future-only-protocol"
        ],
        "adopterAction": "Reject plugins that do not negotiate protocol 1 with the current host, even when their registry entry is otherwise complete.",
        "rollbackAction": "Require host upgrade evidence or republish with current protocol compatibility before install."
      },
      {
        "id": "integrity-or-provenance-missing",
        "cases": [
          "digest-mismatch",
          "signature-provenance"
        ],
        "adopterAction": "Reject digest mismatches and require signature provenance in release notes before trusting third-party plugin binaries.",
        "rollbackAction": "Disable the plugin release and keep the last digest-matched version available for rollback."
      },
      {
        "id": "permission-or-filesystem-escape",
        "cases": [
          "permission-escape",
          "malicious-path",
          "no-partial-writes"
        ],
        "adopterAction": "Reject plugins that request permissions outside filesystem:write-relative, attempt path escape, or leave partial writes on failure.",
        "rollbackAction": "Keep plugin effects disabled and require a clean conformance rerun before allowing filesystem mutation."
      }
    ],
    "templatePublishingRequirements": [
      "template schema",
      "entrypoints",
      "permissions",
      "checksum",
      "source",
      "dry-run evidence"
    ]
  },
  "protocol": {
    "current": "1",
    "schemaEvidence": "cmd/gofly/internal/generator/plugin.go",
    "contractTest": "TestPluginProtocolSchemaContract"
  },
  "cases": [
    {
      "id": "registry-schema",
      "category": "registry",
      "expected": "pass",
      "evidence": [
        "cmd/gofly/internal/generator/plugin.go",
        "cmd/gofly/internal/generator/plugin_test.go",
        "examples/plugin-ecosystem/registry/plugins.json"
      ],
      "tests": [
        "TestPluginRegistryIndexValidationAndFiltering"
      ],
      "failurePolicy": "registry entries missing checksum, source, protocol, manifest, dry-run, or permissions fail before publication"
    },
    {
      "id": "manifest-schema",
      "category": "manifest",
      "expected": "pass",
      "evidence": [
        "cmd/gofly/internal/generator/plugin.go",
        "docs/reference/plugin-publishing-ux.json"
      ],
      "tests": [
        "TestPluginManifestContractValidation",
        "TestPluginProtocolSchemaContract"
      ],
      "failurePolicy": "unsupported capabilities, unsupported permissions, and incompatible manifests fail before plugin effects run"
    },
    {
      "id": "old-protocol",
      "category": "compatibility",
      "compatibleVersions": [
        "0"
      ],
      "expected": "reject",
      "evidence": [
        "cmd/gofly/internal/generator/plugin_test.go",
        "docs/reference/plugin-publishing-ux.json"
      ],
      "tests": [
        "TestPluginProtocolCompatibilityMatrix"
      ],
      "failurePolicy": "old-protocol-only plugins are rejected for a protocol 1 host"
    },
    {
      "id": "current-protocol",
      "category": "compatibility",
      "compatibleVersions": [
        "1"
      ],
      "expected": "accept",
      "evidence": [
        "cmd/gofly/internal/generator/plugin_test.go",
        "docs/reference/plugin-publishing-ux.json"
      ],
      "tests": [
        "TestPluginProtocolCompatibilityMatrix"
      ],
      "failurePolicy": "current protocol plugins may run only after manifest, digest, and permission checks pass"
    },
    {
      "id": "future-plus-current-protocol",
      "category": "compatibility",
      "compatibleVersions": [
        "2",
        "1"
      ],
      "expected": "accept",
      "evidence": [
        "cmd/gofly/internal/generator/plugin_test.go",
        "docs/reference/plugin-publishing-ux.json"
      ],
      "tests": [
        "TestPluginProtocolCompatibilityMatrix"
      ],
      "failurePolicy": "future-capable plugins must keep protocol 1 behavior active until the host upgrades"
    },
    {
      "id": "future-only-protocol",
      "category": "compatibility",
      "compatibleVersions": [
        "2"
      ],
      "expected": "reject",
      "evidence": [
        "cmd/gofly/internal/generator/plugin_test.go",
        "docs/reference/plugin-publishing-ux.json"
      ],
      "tests": [
        "TestPluginProtocolCompatibilityMatrix"
      ],
      "failurePolicy": "future-only plugins are rejected until the host understands the future protocol"
    },
    {
      "id": "digest-mismatch",
      "category": "digest",
      "expected": "reject",
      "evidence": [
        "cmd/gofly/internal/generator/plugin.go",
        "cmd/gofly/internal/generator/plugin_test.go"
      ],
      "tests": [
        "TestResolveRemotePluginRejectsDigestMismatch"
      ],
      "failurePolicy": "downloaded plugin bytes must match the registry sha256 digest and fail closed before cache promotion"
    },
    {
      "id": "signature-provenance",
      "category": "signature",
      "expected": "record",
      "evidence": [
        "docs/reference/plugin-publishing-ux.json",
        "examples/plugin-ecosystem/main.go"
      ],
      "tests": [
        "TestPluginEcosystemReport"
      ],
      "failurePolicy": "publisher release notes must record signature provenance before publishing third-party plugins"
    },
    {
      "id": "permission-escape",
      "category": "permission",
      "expected": "reject",
      "evidence": [
        "cmd/gofly/internal/generator/plugin.go",
        "cmd/gofly/internal/generator/plugin_test.go"
      ],
      "tests": [
        "TestPluginManifestContractValidation",
        "TestPluginRegistryIndexValidationAndFiltering"
      ],
      "failurePolicy": "permissions outside filesystem:write-relative are rejected before plugin effects run"
    },
    {
      "id": "malicious-path",
      "category": "filesystem",
      "expected": "reject",
      "evidence": [
        "cmd/gofly/internal/generator/plugin.go",
        "cmd/gofly/internal/generator/plugin_test.go"
      ],
      "tests": [
        "TestPluginResponseWriteFilesRejectsEscapingPaths",
        "TestPluginResponseRejectsSymlinkParentTraversal",
        "TestPluginResponseRejectsSymlinkLeaf"
      ],
      "failurePolicy": "file and patch paths must stay relative to the project root and reject symlink traversal"
    },
    {
      "id": "no-partial-writes",
      "category": "failure-isolation",
      "expected": "reject",
      "evidence": [
        "cmd/gofly/internal/generator/plugin.go",
        "cmd/gofly/internal/generator/plugin_test.go"
      ],
      "tests": [
        "TestPluginResponseApplyRejectsPartialWritesWhenPatchFails"
      ],
      "failurePolicy": "plugin output application must reject partial writes when any file or patch fails"
    }
  ],
  "releaseGates": [
    "make plugin-conformance-check",
    "go test -shuffle=on ./cmd/gofly/internal/generator -run TestPluginProtocolCompatibilityMatrix",
    "go test -C examples/plugin-ecosystem ./...",
    "go run -C examples/plugin-ecosystem ."
  ]
}
