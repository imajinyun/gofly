      "manifest": {
        "name": "audit-trail-generator",
        "version": "v0.3.0",
        "compatibleVersions": ["1"],
        "capabilities": ["generate:file", "generate:patch"],
        "permissions": ["filesystem:write-relative"],
        "requiresDryRun": true
      }
    },
    {
      "name": "company-template-pack",
      "remote": "https://plugins.example.com/gofly/company-template-pack",
