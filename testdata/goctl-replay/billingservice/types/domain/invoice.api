syntax = "v1"
import "shared/common.api"

// MoneyAmount is imported through a nested domain fixture to prove comment
// stripping, tag preservation, and transitive import resolution.
type MoneyAmount {
  Currency string `json:"currency"`
  Units int64 `json:"units"`
  Nanos int32 `json:"nanos"`
}

type InvoiceLine {
  Sku string `json:"sku"`
  Quantity int64 `json:"quantity"`
  Amount MoneyAmount `json:"amount"`
}

type InvoiceSummary {
  ID int64 `json:"id"`
  CustomerID int64 `json:"customerId"`
  Status string `json:"status"`
  Total MoneyAmount `json:"total"`
  Meta RequestMeta `json:"meta"`
}
