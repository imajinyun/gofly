syntax = "v1"
import "types/common.api"

type CreateInventoryRequest {
  Sku string `json:"sku"`
  WarehouseID int64 `json:"warehouseId"`
  Available int64 `json:"available"`
  Meta AuditMeta `json:"meta"`
}

type CreateInventoryResponse {
  ID int64 `json:"id"`
  Version int64 `json:"version"`
}

type GetInventoryRequest {
  ID int64 `path:"id"`
  RequestID string `header:"X-Request-ID"`
}

type GetInventoryResponse {
  ID int64 `json:"id"`
  Sku string `json:"sku"`
  WarehouseID int64 `json:"warehouseId"`
  Available int64 `json:"available"`
  Reserved int64 `json:"reserved"`
  Version int64 `json:"version"`
}

type ListInventoryRequest {
  Page PageRequest `json:"page"`
  WarehouseID int64 `form:"warehouseId"`
}

type ListInventoryResponse {
  Items []GetInventoryResponse `json:"items"`
  Page PageResponse `json:"page"`
}

type AdjustInventoryRequest {
  ID int64 `path:"id"`
  Delta int64 `json:"delta"`
  ExpectedVersion int64 `json:"expectedVersion"`
  Meta AuditMeta `json:"meta"`
}

type AdjustInventoryResponse {
  ID int64 `json:"id"`
  Available int64 `json:"available"`
  Version int64 `json:"version"`
}

@server(group: inventory prefix: /api/v1 jwt: Auth middlewares: auth,trace,audit)
service inventory-api {
  @handler createInventory
  post /inventory (CreateInventoryRequest) returns (CreateInventoryResponse)

  @handler getInventory
  get /inventory/:id (GetInventoryRequest) returns (GetInventoryResponse)

  @handler listInventory
  get /inventory (ListInventoryRequest) returns (ListInventoryResponse)
}

@server(group: admin prefix: /api/admin/v1 jwt: AdminAuth middlewares: adminAuth,trace)
service admin-api {
  @handler adjustInventory
  patch /inventory/:id/adjust (AdjustInventoryRequest) returns (AdjustInventoryResponse)
}
