syntax = "v1"
import "types/common.api"

type CreateInventoryReq {
  Sku string `json:"sku"`
  WarehouseID int64 `json:"warehouseId"`
  Available int64 `json:"available"`
  Meta AuditMeta `json:"meta"`
}

type CreateInventoryResp {
  ID int64 `json:"id"`
  Version int64 `json:"version"`
}

type GetInventoryReq {
  ID int64 `path:"id"`
  RequestID string `header:"X-Request-ID"`
}

type GetInventoryResp {
  ID int64 `json:"id"`
  Sku string `json:"sku"`
  WarehouseID int64 `json:"warehouseId"`
  Available int64 `json:"available"`
  Reserved int64 `json:"reserved"`
  Version int64 `json:"version"`
}

type ListInventoryReq {
  Page PageReq `json:"page"`
  WarehouseID int64 `form:"warehouseId"`
}

type ListInventoryResp {
  Items []GetInventoryResp `json:"items"`
  Page PageResp `json:"page"`
}

type AdjustInventoryReq {
  ID int64 `path:"id"`
  Delta int64 `json:"delta"`
  ExpectedVersion int64 `json:"expectedVersion"`
  Meta AuditMeta `json:"meta"`
}

type AdjustInventoryResp {
  ID int64 `json:"id"`
  Available int64 `json:"available"`
  Version int64 `json:"version"`
}

@server(group: inventory prefix: /api/v1 jwt: Auth middlewares: auth,trace,audit)
service inventory-api {
  @handler createInventory
  post /inventory (CreateInventoryReq) returns (CreateInventoryResp)

  @handler getInventory
  get /inventory/:id (GetInventoryReq) returns (GetInventoryResp)

  @handler listInventory
  get /inventory (ListInventoryReq) returns (ListInventoryResp)
}

@server(group: admin prefix: /api/admin/v1 jwt: AdminAuth middlewares: adminAuth,trace)
service admin-api {
  @handler adjustInventory
  patch /inventory/:id/adjust (AdjustInventoryReq) returns (AdjustInventoryResp)
}
