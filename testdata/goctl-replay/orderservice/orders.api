syntax = "v1"

type CreateOrderReq {
  BuyerName string `json:"buyerName"`
  AmountCents int64 `json:"amountCents"`
}

type CreateOrderResp {
  ID int64 `json:"id"`
  Status string `json:"status"`
}

type GetOrderReq {
  ID int64 `path:"id"`
}

type GetOrderResp {
  ID int64 `json:"id"`
  BuyerName string `json:"buyerName"`
  Status string `json:"status"`
}

@server(group: orders prefix: /api/v1 jwt: Auth middlewares: auth,trace)
service orders-api {
  @handler createOrder
  post /orders (CreateOrderReq) returns (CreateOrderResp)

  @handler getOrder
  get /orders/:id (GetOrderReq) returns (GetOrderResp)
}
